# ===================================
# RMS SMTP CF7 - Test Environment
# ===================================
# Copy this file to .env and fill in your SMTP credentials
# NEVER commit .env to version control!

# ===================================
# SMTP Server 1 - Gmail
# ===================================
SMTP_1_HOST=smtp.gmail.com
SMTP_1_PORT=587
SMTP_1_ENCRYPTION=tls
SMTP_1_USERNAME=your-email@gmail.com
SMTP_1_PASSWORD=your-app-password
SMTP_1_FROM_EMAIL=your-email@gmail.com
SMTP_1_FROM_NAME=Your Website Name

# ===================================
# SMTP Server 2 - Outlook/Office 365
# ===================================
SMTP_2_HOST=smtp.office365.com
SMTP_2_PORT=587
SMTP_2_ENCRYPTION=tls
SMTP_2_USERNAME=your-email@outlook.com
SMTP_2_PASSWORD=your-password
SMTP_2_FROM_EMAIL=your-email@outlook.com
SMTP_2_FROM_NAME=Your Website Name

# ===================================
# SMTP Server 3 - SendGrid
# ===================================
SMTP_3_HOST=smtp.sendgrid.net
SMTP_3_PORT=587
SMTP_3_ENCRYPTION=tls
SMTP_3_USERNAME=apikey
SMTP_3_PASSWORD=your-sendgrid-api-key
SMTP_3_FROM_EMAIL=noreply@yourdomain.com
SMTP_3_FROM_NAME=Your Website Name

# ===================================
# SMTP Server 4 - Mailgun
# ===================================
SMTP_4_HOST=smtp.mailgun.org
SMTP_4_PORT=587
SMTP_4_ENCRYPTION=tls
SMTP_4_USERNAME=postmaster@yourdomain.com
SMTP_4_PASSWORD=your-mailgun-password
SMTP_4_FROM_EMAIL=noreply@yourdomain.com
SMTP_4_FROM_NAME=Your Website Name

# ===================================
# SMTP Server 5 - Amazon SES
# ===================================
SMTP_5_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_5_PORT=587
SMTP_5_ENCRYPTION=tls
SMTP_5_USERNAME=your-ses-smtp-username
SMTP_5_PASSWORD=your-ses-smtp-password
SMTP_5_FROM_EMAIL=noreply@yourdomain.com
SMTP_5_FROM_NAME=Your Website Name

# ===================================
# SMTP Server 6 - Custom/Local
# ===================================
SMTP_6_HOST=localhost
SMTP_6_PORT=1025
SMTP_6_ENCRYPTION=none
SMTP_6_USERNAME=
SMTP_6_PASSWORD=
SMTP_6_FROM_EMAIL=noreply@localhost
SMTP_6_FROM_NAME=Local Dev

# ===================================
# Test Configuration
# ===================================
# Email address to send test emails to
TEST_RECIPIENT=your-test-email@example.com

# Which servers to test (comma-separated numbers, or "all")
TEST_SERVERS=all

# Connection timeout in seconds
TEST_TIMEOUT=10

# Enable verbose output
TEST_VERBOSE=true

# ===================================
# WordPress Test Environment (Optional)
# ===================================
WP_TEST_DB_HOST=localhost
WP_TEST_DB_NAME=wordpress_test
WP_TEST_DB_USER=root
WP_TEST_DB_PASSWORD=
WP_TEST_TABLE_PREFIX=wp_test_
